generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  userId    String?
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([eventType])
}
