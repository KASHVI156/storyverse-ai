{
  "name": "storyverse-ai-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "build": "node ../node_modules/prisma/build/index.js generate --schema ../prisma/schema.prisma && node --check src/index.js",
    "test": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --runInBand",
    "seed": "node src/seed/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^5.0.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "jest": "^30.4.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.3",
    "supertest": "^7.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
